<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:MachineSightApp.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="MachineSightApp.Views.CameraView"
             x:DataType="vm:CameraViewModel"
             Background="White"
             Foreground="Black">

            <Panel>
                <TextBlock Text="Pas de signal" 
                        IsVisible="{Binding CurrentFrame, Converter={x:Static ObjectConverters.IsNull}}"/>
                <Image Source="{Binding CurrentFrame}"
                    IsVisible="{Binding CurrentFrame, Converter={x:Static ObjectConverters.IsNotNull}}"/>
            </Panel>

  
</UserControl>
